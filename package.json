{
  "name": "sysext-manager",
  "version": "0.8.1",
  "description": "Decky plugin to manage SteamOS systemd-sysext extensions",
  "type": "module",
  "scripts": {
    "build": "rollup -c && sh scripts/bundle-extensions.sh",
    "watch": "rollup -c -w",
    "clean": "rm -rf dist/ py_modules/backend/",
    "rebuild-extension-images": "rm -rf assets/extensions/*.raw && ./build-extension-images.sh",
    "validate": "./scripts/validate-extensions.sh",
    "test": ".venv/bin/python -m pytest tests/ -v"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bentemple/steamos-extensions.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "steamos",
    "extensions",
    "sysext"
  ],
  "author": "bentemple",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bentemple/steamos-extensions/issues"
  },
  "homepage": "https://github.com/bentemple/steamos-extensions#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
