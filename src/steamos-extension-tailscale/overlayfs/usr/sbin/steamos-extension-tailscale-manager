#!/usr/bin/env bash
# Manager script for Tailscale installation
# Called by steamos-extension-tailscale.service on each boot.
# Skips installation if Tailscale is already installed; runs tailscale.sh otherwise.
# Records the installed version to a state file after a successful install.
set -eu -o pipefail

INSTALL_SCRIPT="/usr/share/steamos-extension-tailscale/tailscale.sh"
TAILSCALE_BIN="/opt/tailscale/tailscaled"
STATE_DIR="/home/deck/.local/share/steamos-extension-tailscale"
VERSION_FILE="$STATE_DIR/version"

# If tailscaled is already installed and enabled, skip install
if systemctl is-enabled --quiet tailscaled 2>/dev/null && [[ -x "$TAILSCALE_BIN" ]]; then
    echo "Tailscale is already installed — skipping install."
    exit 0
fi

echo "Running Tailscale installer..."
# Change to install script directory so relative paths (e.g., override.conf) work
cd "$(dirname "$INSTALL_SCRIPT")"
if "$INSTALL_SCRIPT"; then
    # Record the installed version for the update-manager
    if [[ -x "$TAILSCALE_BIN" ]]; then
        mkdir -p "$STATE_DIR"
        "$TAILSCALE_BIN" --version 2>/dev/null | head -1 | awk '{print $1}' > "$VERSION_FILE" || true
        echo "Recorded installed version: $(cat "$VERSION_FILE" 2>/dev/null || echo unknown)"
    fi
else
    echo "Tailscale installer failed." >&2
    exit 1
fi
