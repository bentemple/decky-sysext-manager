#!/usr/bin/env zsh
set -e

# Read persistence config (default: true for backwards compatibility)
ENABLE_PERSISTENCE=true
CONFIG_FILE="/var/lib/extensions-config/loader/config"
if [[ -f "$CONFIG_FILE" ]]; then
	while IFS='=' read -r key value; do
		[[ "$key" == "enable_persistence" ]] && ENABLE_PERSISTENCE="$value"
	done < "$CONFIG_FILE"
fi

if [[ "$ENABLE_PERSISTENCE" != "true" ]]; then
	# Persistence disabled - clean up /etc/ files if they exist
	rm -f /etc/atomic-update.conf.d/steamos-extension-loader.conf
	rm -f /etc/systemd/system/steamos-extension-loader.service
	rm -f /etc/steamos-extension-loader
	systemctl daemon-reload || true
	exit 0
fi

# Persistence enabled - proceed with normal installation to /etc/
function same {
	[[ -f $1 ]] && [[ -f $2 ]] && [[ "$(md5sum < $1)" == "$(md5sum < $2)" ]]
}

if ! [[ -e /etc/atomic-update.conf.d ]]; then
	mkdir /etc/atomic-update.conf.d
fi

if ! same \
	/usr/share/steamos-extension-loader-atomic-update.conf \
	/etc/atomic-update.conf.d/steamos-extension-loader.conf
then
	echo mkdir -p /etc/atomic-update.conf.d
	cp \
		/usr/share/steamos-extension-loader-atomic-update.conf \
		/etc/atomic-update.conf.d/steamos-extension-loader.conf
fi

if ! same \
	/usr/share/steamos-extension-loader.service \
	/etc/systemd/system/steamos-extension-loader.service
then
	cp \
		/usr/share/steamos-extension-loader.service \
		/etc/systemd/system/steamos-extension-loader.service

	systemctl daemon-reload || true
	systemctl stop --no-block steamos-extension-loader.service || true
fi

if ! same \
	/usr/share/steamos-extension-loader \
	/etc/steamos-extension-loader
then
	cp \
		/usr/share/steamos-extension-loader \
		/etc/steamos-extension-loader

	chmod +x /etc/steamos-extension-loader
	systemctl stop --no-block steamos-extension-loader.service || true
fi

systemctl enable --now --no-block steamos-extension-loader.service || true
