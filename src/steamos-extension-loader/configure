#!/usr/bin/env bash
set -e

CONFIG_DIR="/var/lib/extensions-config/loader"
CONFIG_FILE="$CONFIG_DIR/config"

mkdir -p "$CONFIG_DIR"

# Load existing config if present
declare -A config
if [[ -f "$CONFIG_FILE" ]]; then
    while IFS='=' read -r key value; do
        [[ -z "$key" || "$key" =~ ^# ]] && continue
        config["$key"]="$value"
    done < "$CONFIG_FILE"
fi

# Parse arguments and update config
for arg in "$@"; do
    case "$arg" in
        --*=*)
            key="${arg#--}"
            key="${key%%=*}"
            value="${arg#*=}"
            config["$key"]="$value"
            ;;
    esac
done

# Write config file
> "$CONFIG_FILE"
for key in "${!config[@]}"; do
    echo "$key=${config[$key]}" >> "$CONFIG_FILE"
done
