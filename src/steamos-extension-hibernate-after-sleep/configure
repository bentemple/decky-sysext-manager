#!/bin/bash
# Configure script for hibernate-after-sleep extension
# Called by Decky plugin with CLI args: --HibernateDelaySec=30min --TargetSwapFileSizeInGbs=16
set -e

CONFIG_FILE="/var/lib/extensions-config/hibernate-after-sleep"
INSTALL_SCRIPT="/usr/sbin/steamos-extension-hibernate-after-sleep-install"

# Parse CLI arguments
declare -A config_values
for arg in "$@"; do
    if [[ "$arg" =~ ^--([^=]+)=(.*)$ ]]; then
        key="${BASH_REMATCH[1]}"
        value="${BASH_REMATCH[2]}"
        config_values["$key"]="$value"
    fi
done

# Ensure config directory exists
mkdir -p "$(dirname "$CONFIG_FILE")"

# Read existing config or start fresh
declare -A existing_config
if [[ -f "$CONFIG_FILE" ]]; then
    while IFS='=' read -r key value; do
        # Skip comments and empty lines
        [[ "$key" =~ ^# ]] && continue
        [[ -z "$key" ]] && continue
        # Clean the key and value
        key=$(echo "$key" | tr -d ' ')
        value=$(echo "$value" | tr -d '"' | tr -d ' ')
        [[ -n "$key" ]] && existing_config["$key"]="$value"
    done < "$CONFIG_FILE"
fi

# Merge new values
for key in "${!config_values[@]}"; do
    existing_config["$key"]="${config_values[$key]}"
done

# Write config file
{
    echo "# Configuration for hibernate-after-sleep extension"
    echo "# Generated by Decky plugin"
    echo ""
    for key in "${!existing_config[@]}"; do
        value="${existing_config[$key]}"
        # Convert plain integer minutes to systemd duration format (e.g. 60 → 60min)
        if [[ "$key" == "HibernateDelaySec" ]] && [[ "$value" =~ ^[0-9]+$ ]]; then
            value="${value}min"
        fi
        echo "${key}=${value}"
    done
} > "$CONFIG_FILE"

# Set ownership to deck user
chown deck:deck "$CONFIG_FILE"

echo "Configuration updated: $CONFIG_FILE"

# If the extension is already installed and active, apply settings immediately
# by re-running the installer script (which reads the config file).
# This ensures changes take effect without requiring a reboot.
if systemctl is-enabled --quiet steamos-extension-hibernate-after-sleep-install.service 2>/dev/null; then
    if [[ -x "$INSTALL_SCRIPT" ]]; then
        echo "Extension is active — applying settings now..."
        "$INSTALL_SCRIPT" --force
        echo "Settings applied."
    fi
else
    echo "Note: Changes will be applied on next reboot when the installer service runs."
fi
